---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>Kairos AI - Soluciones de IA y Desarrollo de Software para Empresas</title>
    <meta name="title" content="Kairos AI - Soluciones de IA y Desarrollo de Software para Empresas">
    <meta name="description" content="Impulsa tu empresa con IA y automatizaciones inteligentes. Desarrollo web, móvil y agentes de IA. Transforma datos en decisiones estratégicas.">

    <link rel="canonical" href="https://kairos-ai.tech/">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kairos-ai.tech/">
    <meta property="og:site_name" content="Kairos AI">
    <meta property="og:locale" content="es_MX">
    <meta property="og:title" content="Kairos AI - Soluciones de IA para Empresas">
    <meta property="og:description" content="Aprovecha la mejor tecnología para crear soluciones de software que optimizan tus recursos.">
    <meta property="og:image" content="https://kairos-ai.tech/assets/branding/kairosai-labs-seo.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://kairos-ai.tech/">
    <meta property="twitter:title" content="Kairos AI - Soluciones de IA para Empresas">
    <meta property="twitter:description" content="Aprovecha la mejor tecnología para crear soluciones de software que optimizan tus recursos.">
    <meta property="twitter:image" content="https://kairos-ai.tech/assets/branding/kairosai-labs-seo.png">

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Kairos AI",
        "url": "https://kairos-ai.tech",
        "logo": "https://kairos-ai.tech/assets/branding/kairosai-labs-seo.png",
        "description": "Soluciones de IA y desarrollo de software para empresas",
        "sameAs": [
          "https://linkedin.com/company/kairosai"
        ]
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
