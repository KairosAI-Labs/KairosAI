---
// src/components/IntegrationIcon.astro
const { src, alt } = Astro.props;
---

<div class="w-16 h-16 md:w-20 md:h-20 bg-[#151515] border border-white/5 rounded-[22px] flex items-center justify-center p-4 shadow-2xl transition-transform hover:scale-110">
  <img src={src} alt={alt} class="w-full h-full object-contain" />
</div>