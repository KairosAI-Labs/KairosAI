---
import { cn } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<article
  class={cn(
    'w-[350px] h-[200px] text-center rounded-2xl border-glass',
    className
  )}
>
  <div class="flex flex-col gap-4 bg-black py-4 px-5 h-full">
    <h3 class="font-bold text-4xl">
      {title}
    </h3>
    <p class="font-extralight line-clamp-4">
      {description}
    </p>
  </div>
</article>
