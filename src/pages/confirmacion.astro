---
import Layout from '@/layouts/Layout.astro';
import * as jose from 'jose';
import {
  N8N_WEBHOOK_URL_BASE,
  N8N_WEBHOOK_TOKEN,
  N8N_SECRET_TOKEN,
} from '@/constants/env';
import { CheckCircle2, AlertCircle, Clock, ArrowLeft, Mail, Sparkles } from 'lucide-react';

type Estado = 'ok' | 'token_invalido' | 'token_expirado' | 'webhook_error';

let estado: Estado = 'token_invalido';

const token = Astro.url.searchParams.get('token');
if (token) {
  try {
    const secret = new TextEncoder().encode(N8N_SECRET_TOKEN);
    await jose.jwtVerify(token, secret);

    const webhookUrl = `${N8N_WEBHOOK_URL_BASE}/verificarAgendamiento?token=${encodeURIComponent(token)}`;
    console.log(webhookUrl);

    const response = await fetch(webhookUrl, {
      method: 'GET',
      headers: {
        Authorization: `Bearer ${N8N_WEBHOOK_TOKEN}`,
      },
    });

    console.log(response, token);

    if (response.ok) {
      estado = 'ok';
    } else {
      estado = 'webhook_error';
    }
  } catch (err) {
    console.error('[confirmacion] JWT error:', err);
    if (err instanceof jose.errors.JWTExpired) {
      estado = 'token_expirado';
    } else {
      estado = 'token_invalido';
    }
  }
}
---

<Layout>
  <main class="min-h-screen w-full flex items-center justify-center relative overflow-hidden">
    {/* Animated Background */}
    <div class="absolute inset-0 bg-black">
      {/* Gradient orbs */}
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-[120px] animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-secondary/15 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1s;" />
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 bg-tertiary/10 rounded-full blur-[80px] animate-pulse" style="animation-delay: 2s;" />
      
      {/* Grid pattern overlay */}
      <div class="absolute inset-0 bg-[linear-gradient(rgba(134,86,236,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(134,86,236,0.03)_1px,transparent_1px)] bg-[size:60px_60px]" />
    </div>

    {/* Content Card */}
    <div class="relative z-10 w-full max-w-lg mx-4">
      {/* Glowing border effect */}
      <div class="absolute -inset-[1px] bg-gradient-to-r from-primary via-secondary to-tertiary rounded-3xl opacity-50 blur-sm" />
      <div class="absolute -inset-[1px] bg-gradient-to-r from-primary via-secondary to-tertiary rounded-3xl opacity-30" />
      
      <div class="relative bg-black/90 backdrop-blur-xl rounded-3xl p-8 md:p-12 border border-white/10">
        {/* Logo / Brand */}
        <div class="flex items-center justify-center gap-2 mb-10">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
            <Sparkles className="w-4 h-4 text-white" />
          </div>
          <span class="text-lg font-semibold text-white/90 tracking-tight">Kairos AI</span>
        </div>

        {/* Estado: OK - Confirmación exitosa */}
        {estado === 'ok' && (
          <div class="text-center animate-in fade-in slide-in-from-bottom-4 duration-700">
            {/* Success Icon with gradient ring */}
            <div class="relative mx-auto w-24 h-24 mb-8">
              <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/30 to-emerald-400/10 rounded-full animate-ping" style="animation-duration: 3s;" />
              <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/20 to-emerald-400/5 rounded-full" />
              <div class="relative w-full h-full rounded-full bg-gradient-to-br from-emerald-500/10 to-emerald-400/5 border border-emerald-500/30 flex items-center justify-center">
                <CheckCircle2 className="w-12 h-12 text-emerald-400" strokeWidth={1.5} />
              </div>
            </div>

            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
              ¡Todo listo!
            </h1>
            
            <p class="text-white/60 text-base md:text-lg leading-relaxed mb-8 max-w-sm mx-auto">
              Tu reunión ha sido confirmada exitosamente. Hemos enviado los detalles a tu correo.
            </p>

            {/* Info Box */}
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 mb-8">
              <div class="flex items-center gap-3 text-white/70">
                <Mail className="w-5 h-5 text-primary" />
                <span class="text-sm">Revisa tu bandeja de entrada</span>
              </div>
            </div>

            {/* CTA Button */}
            <a 
              href="/"
              class="group inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary rounded-xl text-white font-medium transition-all duration-300 hover:shadow-[0_0_30px_rgba(134,86,236,0.4)] hover:scale-[1.02]"
            >
              <ArrowLeft className="w-4 h-4 transition-transform group-hover:-translate-x-1" />
              Volver al inicio
            </a>
          </div>
        )}

        {/* Estado: Token Expirado */}
        {estado === 'token_expirado' && (
          <div class="text-center animate-in fade-in slide-in-from-bottom-4 duration-700">
            {/* Expired Icon */}
            <div class="relative mx-auto w-24 h-24 mb-8">
              <div class="absolute inset-0 bg-gradient-to-br from-amber-500/30 to-amber-400/10 rounded-full" />
              <div class="relative w-full h-full rounded-full bg-gradient-to-br from-amber-500/10 to-amber-400/5 border border-amber-500/30 flex items-center justify-center">
                <Clock className="w-12 h-12 text-amber-400" strokeWidth={1.5} />
              </div>
              {/* Clock animation */}
              <div class="absolute inset-0 border-2 border-amber-500/20 rounded-full animate-ping" style="animation-duration: 2s;" />
            </div>

            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
              Enlace expirado
            </h1>
            
            <p class="text-white/60 text-base md:text-lg leading-relaxed mb-8 max-w-sm mx-auto">
              Este enlace de confirmación ya no es válido. Los enlaces tienen un tiempo límite de seguridad.
            </p>

            <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-4 mb-8">
              <p class="text-amber-200/80 text-sm">
                Por favor solicita una nueva reunión para recibir un enlace actualizado.
              </p>
            </div>

            {/* CTA Button */}
            <a 
              href="/"
              class="group inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-amber-600 rounded-xl text-white font-medium transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.4)] hover:scale-[1.02]"
            >
              <ArrowLeft className="w-4 h-4 transition-transform group-hover:-translate-x-1" />
              Solicitar nueva reunión
            </a>
          </div>
        )}

        {/* Estado: Error (Token inválido o webhook) */}
        {(estado === 'token_invalido' || estado === 'webhook_error') && (
          <div class="text-center animate-in fade-in slide-in-from-bottom-4 duration-700">
            {/* Error Icon */}
            <div class="relative mx-auto w-24 h-24 mb-8">
              <div class="absolute inset-0 bg-gradient-to-br from-rose-500/30 to-rose-400/10 rounded-full" />
              <div class="relative w-full h-full rounded-full bg-gradient-to-br from-rose-500/10 to-rose-400/5 border border-rose-500/30 flex items-center justify-center animate-pulse" style="animation-duration: 2s;">
                <AlertCircle className="w-12 h-12 text-rose-400" strokeWidth={1.5} />
              </div>
            </div>

            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
              {estado === 'token_invalido' ? 'Enlace inválido' : 'Error de conexión'}
            </h1>
            
            <p class="text-white/60 text-base md:text-lg leading-relaxed mb-8 max-w-sm mx-auto">
              {estado === 'token_invalido' 
                ? 'El enlace de confirmación no es válido o ha sido modificado. Intenta nuevamente.'
                : 'Ocurrió un error al procesar tu confirmación. Por favor intenta de nuevo más tarde.'}
            </p>

            <div class="bg-rose-500/10 border border-rose-500/20 rounded-xl p-4 mb-8">
              <p class="text-rose-200/80 text-sm">
                {estado === 'token_invalido'
                  ? 'Asegúrate de usar el enlace completo enviado a tu correo.'
                  : 'Si el problema persiste, contacta a nuestro equipo de soporte.'}
              </p>
            </div>

            {/* CTA Button */}
            <a 
              href="/"
              class="group inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-rose-500 to-rose-600 rounded-xl text-white font-medium transition-all duration-300 hover:shadow-[0_0_30px_rgba(244,63,94,0.4)] hover:scale-[1.02]"
            >
              <ArrowLeft className="w-4 h-4 transition-transform group-hover:-translate-x-1" />
              Volver al inicio
            </a>
          </div>
        )}

        {/* Footer note */}
        <div class="mt-10 pt-6 border-t border-white/5 text-center">
          <p class="text-white/30 text-xs">
            © 2025 Kairos AI · Todos los derechos reservados
          </p>
        </div>
      </div>
    </div>

    {/* Floating particles */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 35%; left: 25%; animation-delay: 0s; animation-duration: 3s;"></div>
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 50%; left: 40%; animation-delay: 0.5s; animation-duration: 3s;"></div>
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 65%; left: 55%; animation-delay: 1s; animation-duration: 3s;"></div>
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 45%; left: 70%; animation-delay: 1.5s; animation-duration: 3s;"></div>
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 30%; left: 80%; animation-delay: 2s; animation-duration: 3s;"></div>
      <div class="absolute w-1 h-1 bg-primary/40 rounded-full animate-pulse" style="top: 70%; left: 20%; animation-delay: 2.5s; animation-duration: 3s;"></div>
    </div>
  </main>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>